READYSHELL QUICK REFUSE: CAT "RSHELP"|MORECLEAR - REDRAW SHELLEG: CLEARLST - LIST FILESEG: LST | MOREDRVI - DRIVE INFOEG: DRVI 9CAT - READ TEXTEG: CAT "NOTES"COPY - COPY FILEEG: COPY "A","B"REN - RENAME FILEEG: REN "A","B"DEL - SCRATCH FILEEG: DEL "NOTES"PUT - WRITE SEQ FILEEG: PUT $A,"NOTES"ADD - APPEND SEQ FILEEG: ADD $A,"NOTES"PRT - PRINT VALUEEG: PRT "HI",5MORE - PAGE OUTPUTEG: GEN 40 | MORESEL - PICK FIELDSEG: LST|SEL "NAME"TOP - FIRST N ITEMSEG: LST | TOP 3GEN - COUNT 1..NEG: GEN 5LDV - LOAD VALUEEG: $A=LDV "SNAP"STV - SAVE VALUEEG: STV $A,"SNAP"HELP - SHOW HINTEG: HELPVER - SHOW VERSIONEG: VERTAP - INTERNAL DEBUGEG: GEN 3 | TAP